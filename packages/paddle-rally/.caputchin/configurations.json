{
  "schema": {
    "mode": { "type": "list", "values": ["rival", "solo"], "name": "Mode (rival = vs CPU, solo = keep it alive)" },
    "target": { "type": "range", "min": 3, "max": 7, "step": 1, "name": "Points to win (rival) / returns to survive (solo)" },
    "paddle_speed": { "type": "range", "min": 3, "max": 12, "step": 1, "name": "Paddle speed" },
    "cpu_difficulty": { "type": "range", "min": 5, "max": 10, "step": 1, "name": "Difficulty (5 easiest)" },
    "sound": { "type": "boolean", "name": "Sound" }
  },
  "presets": {
    "default": {
      "_default": true,
      "mode": "rival",
      "target": 3,
      "paddle_speed": 6,
      "cpu_difficulty": 5,
      "sound": true
    },
    "hardcore": {
      "_extends": "default",
      "target": 5,
      "cpu_difficulty": 8
    },
    "solo": {
      "_extends": "default",
      "mode": "solo",
      "target": 5,
      "cpu_difficulty": 5
    },
    "solo-fast": {
      "_extends": "default",
      "mode": "solo",
      "target": 5,
      "cpu_difficulty": 8
    }
  }
}
