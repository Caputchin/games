      "name": "Caputchin",
      "url": "https://caputchin.com"
    }
  },
  "npm": "@caputchin/game-voidshot",
  "entry": "dist/voidshot.js",
  "run": {
    "entry": "dist/run.js",
    "modules": [
      {
        "name": "voidshot.wasm",
        "path": "dist/voidshot.wasm",
        "type": "wasm"
      }
    ]
  },
  "preferred": {
    "width": 480,
    "height": 480
  },
  "minSolveMs": 2500
}
