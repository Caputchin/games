{
  "name": "@caputchin/game-phobos",
  "version": "0.2.4",
  "description": "Clear the demons to prove you're human. A real DOOM-engine captcha. A Caputchin first-party game.",
  "keywords": [
    "caputchin",
    "caputchin-game",
    "captcha",
    "doom",
    "fps",
    "game"
  ],
  "homepage": "https://github.com/Caputchin/caputchin-games#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Caputchin/caputchin-games",
    "directory": "packages/phobos"
  },
  "license": "GPL-2.0-only",
  "private": false,
  "type": "module",
  "files": [
    "dist",
    "caputchin.json",
    ".caputchin",
    "LICENSE",
    "THIRD-PARTY-NOTICES.md",
    "TRADEMARK.md"
  ],
  "sideEffects": [
    "./dist/phobos.js"
  ],
  "scripts": {
    "build:engines": "bash scripts/build-engines.sh",
    "build:engines:headless": "PH_HEADLESS_ONLY=1 bash scripts/build-engines.sh",
    "build:engines:live": "PH_LIVE_ONLY=1 bash scripts/build-engines.sh",
    "pretest": "[ -f build/phobos-headless.wasm ] || pnpm build:engines:headless",
    "test": "vitest run",
    "test:watch": "vitest",
    "prebuild": "{ [ -f build/phobos-headless.wasm ] || pnpm build:engines:headless; } && { [ -f src/generated/phobos-live-wasm.ts ] || pnpm build:engines:live; }",
    "build": "tsup",
    "predev": "{ [ -f build/phobos-headless.wasm ] || pnpm build:engines:headless; } && { [ -f src/generated/phobos-live-wasm.ts ] || pnpm build:engines:live; }",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "check": "node scripts/check.mjs"
  },
  "devDependencies": {
    "@caputchin/determinism": "^0.2.0",
    "@caputchin/game-sdk": "^3.2.0",
    "@caputchin/replay-contract": "^0.3.0",
    "@caputchin/replay-selfcheck": "^0.2.0",
    "@caputchin/replay-wasm": "^0.3.0",
    "@types/node": "^20.0.0",
    "happy-dom": "^15.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
