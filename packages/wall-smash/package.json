{
  "name": "@caputchin/game-wall-smash",
  "version": "0.2.1",
  "description": "Smash the wall of bricks with the ball to prove you're human. A Bevy-engine captcha. A Caputchin first-party game.",
  "keywords": [
    "caputchin",
    "caputchin-game",
    "captcha",
    "bevy",
    "breakout",
    "arkanoid",
    "game"
  ],
  "homepage": "https://github.com/Caputchin/caputchin-games#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Caputchin/caputchin-games",
    "directory": "packages/wall-smash"
  },
  "license": "MIT",
  "private": false,
  "type": "module",
  "files": [
    "dist",
    "caputchin.json",
    ".caputchin",
    "LICENSE",
    "THIRD-PARTY-NOTICES.md"
  ],
  "sideEffects": [
    "./dist/wall-smash.js"
  ],
  "scripts": {
    "build:wasm": "bash scripts/build-wasm.sh",
    "build:wasm:headless": "WS_HEADLESS_ONLY=1 bash scripts/build-wasm.sh",
    "build:wasm:live": "WS_LIVE_ONLY=1 bash scripts/build-wasm.sh",
    "pretest": "[ -f build/wall-smash-headless.wasm ] || pnpm build:wasm:headless",
    "test": "cargo test && vitest run",
    "test:watch": "vitest",
    "prebuild": "{ [ -f build/wall-smash-headless.wasm ] || pnpm build:wasm:headless; } && { [ -f src/generated/live-wasm.ts ] || pnpm build:wasm:live; }",
    "build": "tsup",
    "predev": "{ [ -f build/wall-smash-headless.wasm ] || pnpm build:wasm:headless; } && { [ -f src/generated/live-wasm.ts ] || pnpm build:wasm:live; }",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@caputchin/game-sdk": "^3.0.0",
    "@caputchin/replay-contract": "^0.2.0",
    "@types/node": "^20.0.0",
    "fflate": "^0.8.2",
    "happy-dom": "^15.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
